<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>login page</title>
    <link rel="stylesheet" href="stylesheets/login.css" />
  </head>
  <body>
    <div id="gradient-bg">
      <div calss="gradient-container">
        <div class="gradient1"></div>
        <div class="gradient2"></div>
        <div class="gradient3"></div>
        <div class="gradient4"></div>
        <div class="gradient5"></div>
      </div>
    </div>

    <!-- Form -->
    <form id="form-container" action="/login" method="POST">
      <h1 class="title">Sign in</h1>
      <div class="label">Username</div>
      <input type="text" name="username" />
      <div class="label">Password</div>
      <input type="password" name="password" />
      <button type="submit" class="submit" id="signin-btn">Sign in</button>
      <div class="label msg">
        ◆ You don't have an account? <a href="/signup">Sign up</a>
      </div>
    </form>
  </body>
</html>
